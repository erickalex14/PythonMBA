datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  cedula       String        @unique // Número de Cédula
  name         String?
  password     String        // Contraseña cifrada con bcrypt
  roleId       String
  role         Role          @relation(fields: [roleId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  downloadLogs DownloadLog[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g. "Admin", "Visitante"
  permissions Permission[] // Muchos a muchos implícito en Prisma
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique // e.g. "VIEW_MOVIMIENTOS", "VIEW_LIQUIDACIONES", "VIEW_ATS", "VIEW_LOGS", "DOWNLOAD_EXCEL", "MANAGE_USERS", "MANAGE_CONFIG"
  description String?
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DownloadLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reportType String   // Tipo de reporte
  dateRange  String   // Rango de fechas
  timestamp  DateTime @default(now())
}

model MovimientoStaging {
  id                         Int      @id @default(autoincrement())
  trans_date                 DateTime @db.Date
  product_name               String?
  codigo_producto_convertido String
  original_qty               Decimal  @db.Decimal(18, 4)
  origin_memo                String?
  origin_ref                 String?
  base_comision              Decimal  @db.Decimal(18, 4)
  info_seriales              String?
  codigo_sucursal            String?
  base_imponible_real_1      Decimal  @db.Decimal(18, 4)
  cod_salesman               String?
  codigo_marca               String?
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  @@map("movimientos_staging")
}

model LiquidacionPrincipalStaging {
  liquidacion_id_corp String   @id @db.VarChar(50)
  corp                String   @db.VarChar(10)
  liquidacion_fecha   DateTime @db.Date
  observaciones       String?  @db.Text
  antes_total_1       Decimal  @db.Decimal(18, 4)
  antes_total_2       Decimal  @db.Decimal(18, 4)
  antes_total_3       Decimal  @db.Decimal(18, 4)
  despues_total_1     Decimal  @db.Decimal(18, 4)
  despues_total_2     Decimal  @db.Decimal(18, 4)
  despues_total_3     Decimal  @db.Decimal(18, 4)
  liquidacion_estado  Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@map("liquidaciones_principal_staging")
}

model LiquidacionProductoStaging {
  id                       Int      @id @default(autoincrement())
  liquidacion_id_corp      String   @db.VarChar(50)
  factura_id_corp          String?  @db.VarChar(50)
  id_recepcion_relacionada String?  @db.VarChar(50)
  valor_total_cif          Decimal  @db.Decimal(18, 4)
  valor_subtotal_cif       Decimal  @db.Decimal(18, 4)
  valor_antes_1            Decimal  @db.Decimal(18, 4)
  valor_antes_2            Decimal  @db.Decimal(18, 4)
  valor_antes_3            Decimal  @db.Decimal(18, 4)
  valor_despues_1          Decimal  @db.Decimal(18, 4)
  valor_despues_2          Decimal  @db.Decimal(18, 4)
  valor_despues_3          Decimal  @db.Decimal(18, 4)
  partida_id_corp          String?  @db.VarChar(50)
  producto_id_corp         String?  @db.VarChar(50)
  liquidacion_id           String?  @db.VarChar(50)
  cantidad                 Decimal  @db.Decimal(18, 4)
  precio                   Decimal  @db.Decimal(18, 4)
  total                    Decimal  @db.Decimal(18, 4)
  valor_total_cif_manual   Decimal  @db.Decimal(18, 4)
  valor_total_cif_unidad   Decimal  @db.Decimal(18, 4)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@map("liquidaciones_productos_staging")
}

// Vista SQL eliminada del esquema de Prisma para evitar que db push intente crearla.
// El frontend consulta los datos normalizados a través de los endpoints de FastAPI.

model AtsFacturaStaging {
  doc_id_corp             String   @id @db.VarChar(50)
  invoice_date            DateTime @db.Date
  corp                    String   @db.VarChar(10)
  vendor_id               String   @db.VarChar(50)
  vendor_id_corp          String?  @db.VarChar(60)
  memo                    String?  @db.Text
  invoice_total           Decimal  @db.Decimal(18, 4)
  doc_reference           String?  @db.VarChar(100)
  total_productos_con_iva Decimal  @db.Decimal(18, 4)
  total_servicios_con_iva Decimal  @db.Decimal(18, 4)
  total_productos_sin_iva Decimal  @db.Decimal(18, 4)
  total_servicios_sin_iva Decimal  @db.Decimal(18, 4)
  void                    Boolean  @default(false)
  confirmed               Boolean  @default(true)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@map("ats_facturas_staging")
}

model AtsProveedorStaging {
  vendor_id                String   @id @db.VarChar(50)
  vendor_name              String   @db.VarChar(200)
  ruc_or_fed_id            String?  @db.VarChar(50)
  codigo_proveedor_empresa String?  @db.VarChar(60)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  @@map("ats_proveedores_staging")
}

model AtsFiscalStaging {
  id_relacionado String   @id @db.VarChar(50)
  mf_nume1       Decimal  @db.Decimal(18, 4)
  mf_alfa2       String?  @db.VarChar(100)
  mf_alfa3       String?  @db.VarChar(100)
  mf_lista2      String?  @db.VarChar(100)
  mf_bool5       Boolean  @default(false)
  reservado1     Boolean  @default(false)
  reservado2     Boolean  @default(false)
  reservado3     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("ats_fiscal_staging")
}

model VentasKardexStaging {
  id              Int      @id @default(autoincrement())
  doc_id_corp     String   @db.VarChar(50)
  trans_date      DateTime @db.Date
  product_id_corp String   @db.VarChar(50)
  product_name    String?  @db.VarChar(250)
  quantity        Decimal  @db.Decimal(18, 4)
  original_qty    Decimal  @db.Decimal(18, 4)
  unit_cost       Decimal  @db.Decimal(18, 4)
  discount_amount Decimal  @db.Decimal(18, 4)
  net_line_total  Decimal  @db.Decimal(18, 4)
  um              String?  @db.VarChar(20)
  anulada         Boolean  @default(false)
  in_out          String?  @db.VarChar(10)
  codigo_grupo    String?  @db.VarChar(50)
  codigo_subgrupo String?  @db.VarChar(50)
  origin_memo     String?  @db.VarChar(50)
  origin_ref      String?  @db.VarChar(50)
  trans_cost      Decimal  @default(0) @db.Decimal(18, 4)
  war_code        String?  @db.VarChar(20)
  bodega_nombre   String?  @db.VarChar(100)
  codigo_cliente  String?  @db.VarChar(20)
  nombre_cliente  String?  @db.VarChar(150)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([origin_memo])
  @@index([origin_ref])
  @@index([war_code])
  @@index([codigo_cliente])
  @@map("ventas_kardex_staging")
}

model VentasFacturaStaging {
  doc_id_corp    String   @id @db.VarChar(50)
  doc_reference  String?  @db.VarChar(100)
  invoice_date   DateTime @db.Date
  numero_factura String?  @db.VarChar(50)
  empresa        String?  @db.VarChar(20)
  codigo_local   String?  @db.VarChar(20)
  anulada        Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([numero_factura])
  @@index([empresa])
  @@map("ventas_facturas_staging")
}



